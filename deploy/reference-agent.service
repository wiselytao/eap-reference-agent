[Unit]
Description=Reference Agent Service
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/reference-agent
Environment=REFERENCE_AGENT_CONFIG=/opt/reference-agent/config.yaml
Environment=REFERENCE_AGENT_TOOLS=/opt/reference-agent/TOOLS.md
Environment=REFERENCE_AGENT_PROFILES=/opt/reference-agent/profiles
Environment=OPENAI_API_KEY=CHANGE_ME
Environment=HYBRIDRAG_API_TOKEN=CHANGE_ME
ExecStart=/opt/reference-agent/.venv/bin/uvicorn reference_agent.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
